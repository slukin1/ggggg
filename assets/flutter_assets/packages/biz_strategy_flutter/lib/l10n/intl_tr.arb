  "strategy_first_order" : "Initial Order",
  "strategy_bot_required_margin" : "Margin Required",
  "strategy_bot_required_margin_tip" : "The margin required for the bot is the sum of margin required for the bot's initial order, DCA orders, and take-profit orders. Investment may change slightly as a result of changes in market conditions and other factors.",
