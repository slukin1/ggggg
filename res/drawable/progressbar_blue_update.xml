<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <color android:color="@color/color_10_000000_ffffff" />
    </item>
    <item android:id="@android:id/progress">
        <clip android:gravity="start" android:clipOrientation="horizontal">
            <shape>
                <corners android:radius="1.0dip" />
                <gradient android:startColor="@color/color_1787FB" android:endColor="@color/blue" android:angle="0.0" />
            </shape>
        </clip>
    </item>
</layer-list>