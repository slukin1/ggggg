<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <stroke android:width="@dimen/w_0.5" android:color="@color/light_gray" />
            <corners android:radius="@dimen/margin_padding_5" />
            <color android:color="@color/light_gray" />
        </shape>
    </item>
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape>
                <corners android:radius="@dimen/margin_padding_5" />
                <gradient android:startColor="@color/uikit_transparent" android:endColor="@color/uikit_transparent" android:angle="0.0" />
            </shape>
        </clip>
    </item>
    <item android:id="@android:id/progress">
        <clip android:gravity="start" android:clipOrientation="horizontal">
            <shape>
                <corners android:radius="@dimen/margin_padding_5" />
                <gradient android:startColor="@color/startup_finished" android:endColor="@color/startup_finished" android:angle="0.0" />
            </shape>
        </clip>
    </item>
</layer-list>