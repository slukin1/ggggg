<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="@color/uikit_cmpt_slider_inactive_line_v5" />
            <corners android:radius="@dimen/uikit_radius_small_v5" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <scale android:scaleWidth="100%">
            <shape>
                <solid android:color="@color/uikit_cmpt_button_primary_v5" />
                <corners android:topLeftRadius="@dimen/uikit_dp_4" android:bottomLeftRadius="@dimen/uikit_dp_4" />
            </shape>
        </scale>
    </item>
</layer-list>