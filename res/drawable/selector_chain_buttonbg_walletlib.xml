<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/selector_white" />
            <stroke android:width="@dimen/dp_1" android:color="@color/brand_1" />
            <corners android:radius="@dimen/margin_padding_5" />
            <padding android:left="@dimen/margin_padding_10" android:top="@dimen/margin_padding_5" android:right="@dimen/margin_padding_10" android:bottom="@dimen/margin_padding_5" />
        </shape>
    </item>
    <item android:state_checked="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/selector_white" />
            <stroke android:width="@dimen/dp_1" android:color="@color/selector_d2d2d2" />
            <corners android:radius="@dimen/margin_padding_5" />
        </shape>
    </item>
</selector>