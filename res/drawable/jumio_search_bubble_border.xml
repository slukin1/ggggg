<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <solid android:color="@android:color/transparent" />
            <corners android:radius="@dimen/jumio_radius_small" />
            <stroke android:width="@dimen/jumio_stroke_small" android:color="@color/jumio_primary_dark" />
            <padding android:left="@dimen/jumio_padding_extra_small" android:top="@dimen/jumio_padding_small" android:right="@dimen/jumio_padding_small" android:bottom="@dimen/jumio_padding_small" />
        </shape>
    </item>
    <item android:state_selected="false">
        <shape>
            <solid android:color="@android:color/transparent" />
            <corners android:radius="@dimen/jumio_radius_small" />
            <stroke android:width="@dimen/jumio_stroke_small" android:color="?jumio_search_bubble_background" />
            <padding android:left="@dimen/jumio_padding_extra_small" android:top="@dimen/jumio_padding_small" android:right="@dimen/jumio_padding_small" android:bottom="@dimen/jumio_padding_small" />
        </shape>
    </item>
</selector>