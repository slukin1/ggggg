<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/main_header_bg2" />
            <corners android:radius="@dimen/radius_2" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/main_header_bg2" />
            <corners android:radius="@dimen/radius_2" />
        </shape>
    </item>
    <item android:state_focused="false">
        <shape>
            <solid android:color="@color/bg_theme_red" />
            <corners android:radius="@dimen/radius_2" />
            <stroke android:width="1.0dip" android:color="@color/bg_theme_red" />
        </shape>
    </item>
    <item android:state_pressed="false">
        <shape>
            <solid android:color="@color/bg_theme_red" />
            <corners android:radius="@dimen/radius_2" />
            <stroke android:width="1.0dip" android:color="@color/bg_theme_red" />
        </shape>
    </item>
</selector>